---
const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';
const text = encodeURIComponent(isEs
  ? 'Hola, encontré Cartagena Up y necesito ayuda.'
  : 'Hi! I found Cartagena Up and need help.');
---
<div class="wa-cta">
  <p style="font-size: 0.875rem; color: var(--fg); margin: 0;">
    {isEs
      ? '¿Necesitas un tip local, un lugar para trabajar o un día de playa? '
      : 'Need a local tip, work spot, or beach day? '
    }
    <a href={`https://wa.me/573163946401?text=${text}`}
      target="_blank" rel="noopener"
      style="color: #25D366; font-weight: 600; text-decoration: none;">
      {isEs ? 'Escríbenos por WhatsApp.' : 'Message us on WhatsApp.'}
    </a>
  </p>
</div>
