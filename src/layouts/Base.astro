---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
const { title, description, lang = 'en', canonicalUrl, ogImage = '/og-image.png', jsonLdExtra, additionalJsonLd } = Astro.props;
import { en } from '../i18n/en';
import { es } from '../i18n/es';
const t = lang === 'es' ? es : en;

const workHref  = lang === 'es' ? '/es/work/'   : '/work/';
const eventsHref = lang === 'es' ? '/es/events/' : '/events/';
const aboutHref = lang === 'es' ? '/es/about/'  : '/about/';
const homeHref  = lang === 'es' ? '/es/'         : '/';
const venuesHref = lang === 'es' ? '/es/venues/' : '/venues/';
const archiveHref = lang === 'es' ? '/es/events/archive/' : '/events/archive/';
const sourcesHref = lang === 'es' ? '/es/events/sources/' : '/events/sources/';
const fastestWifiHref = lang === 'es' ? '/es/work/fastest-wifi-cartagena/' : '/work/fastest-wifi-cartagena/';
const wifiSpeedsHref = lang === 'es' ? '/es/work/wifi-speeds-cartagena/' : '/work/wifi-speeds-cartagena/';
const absoluteOgImage = ogImage.startsWith('http')
  ? ogImage
  : `https://cartagenaup.com${ogImage.startsWith('/') ? ogImage : `/${ogImage}`}`;
const enHref = lang === 'es'
  ? `https://cartagenaup.com${Astro.url.pathname.replace(/^\/es/, '') || '/'}`
  : `https://cartagenaup.com${Astro.url.pathname}`;
const esHref = lang === 'es'
  ? `https://cartagenaup.com${Astro.url.pathname}`
  : `https://cartagenaup.com/es${Astro.url.pathname}`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Cartagena Up",
  "url": "https://cartagenaup.com",
  "description": description,
  "inLanguage": lang === 'es' ? "es" : "en",
  ...(jsonLdExtra || {})
});

const currentPath = Astro.url.pathname;
const isWork   = currentPath.includes('/work');
const isEvents = currentPath.includes('/events');
const isAbout  = currentPath.includes('/about');

// Equivalent page in other language, used for language switcher
const altPath = lang === 'es'
  ? (currentPath.replace(/^\/es/, '') || '/')
  : `/es${currentPath}`;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {title.startsWith('Cartagena Up')
    ? <title>{title}</title>
    : <title>{title} · Cartagena Up</title>
  }
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
  <meta property="og:title"       content={title.startsWith('Cartagena Up') ? title : `${title} · Cartagena Up`} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name"   content="Cartagena Up" />
  <meta property="og:image"       content={absoluteOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
  <link rel="alternate" hreflang="en" href={enHref} />
  <link rel="alternate" hreflang="es" href={esHref} />
  <link rel="alternate" hreflang="x-default" href={enHref} />
  <link rel="alternate" type="application/rss+xml" title="Cartagena Up Events" href="/rss.xml" />
  <ClientRouter />
  <script type="application/ld+json" set:html={jsonLd} />
  {additionalJsonLd && <script type="application/ld+json" set:html={JSON.stringify(additionalJsonLd)} />}
  {import.meta.env.PROD && (
    <>
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-113VHTKQ0K"></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-113VHTKQ0K', { send_page_view: false });
        document.addEventListener('astro:page-load', function() {
          gtag('event', 'page_view', {
            page_location: location.href,
            page_title: document.title,
          });
        });
      </script>
    </>
  )}
  <!-- Dark mode: prevent FOUC -->
  <script is:inline>
    (function() {
      var t = localStorage.getItem('cu-theme');
      if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      if (t === 'dark') document.documentElement.classList.add('dark');
    })();
  </script>
</head>
<body id="top">

  <!-- Header — always dark regardless of theme -->
  <header style="background: #1C1A17; position: sticky; top: 0; z-index: 40;">
    <!-- Top row: wordmark | controls -->
    <div style="max-width: 42rem; margin: 0 auto; padding: 0 1.25rem; height: 3rem; display: flex; align-items: center; justify-content: space-between;">
      <a href={homeHref}
        style="font-family: Georgia, serif; font-style: italic; font-weight: 400; font-size: 1.1rem; color: #FAF7F2; text-decoration: none; letter-spacing: -0.01em;">
        Cartagena Up
      </a>
      <div style="display: flex; align-items: center; gap: 1rem;">
        <!-- Theme toggle -->
        <button id="theme-toggle" aria-label="Toggle dark mode"
          style="background: none; border: none; cursor: pointer; color: rgba(250,247,242,0.45); font-size: 0.95rem; padding: 0.25rem; line-height: 1; display: flex; align-items: center;">
          <span id="theme-icon">☾</span>
        </button>
        <!-- Language switcher -->
        <span style="font-size: 0.75rem; letter-spacing: 0.04em; display: flex; align-items: center; gap: 0.35rem;">
          {lang === 'en'
            ? <><span style="color: #C45C26; font-weight: 700;">EN</span><span style="color: rgba(250,247,242,0.2);">·</span><a href={altPath} style="color: rgba(250,247,242,0.45); text-decoration: none; font-weight: 500;">ES</a></>
            : <><a href={altPath} style="color: rgba(250,247,242,0.45); text-decoration: none; font-weight: 500;">EN</a><span style="color: rgba(250,247,242,0.2);">·</span><span style="color: #C45C26; font-weight: 700;">ES</span></>
          }
        </span>
      </div>
    </div>
    <!-- Separator -->
    <div style="border-top: 1px solid rgba(255,255,255,0.07);"></div>
    <!-- Nav row -->
    <nav style="max-width: 42rem; margin: 0 auto; padding: 0 1.25rem; height: 2.25rem; display: flex; align-items: center; gap: 1.5rem;">
      <a href={workHref}
        style={`font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; font-weight: 600; color: ${isWork ? '#C45C26' : 'rgba(250,247,242,0.45)'};`}>
        {t.nav.work}
      </a>
      <a href={eventsHref}
        style={`font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; font-weight: 600; color: ${isEvents ? '#C45C26' : 'rgba(250,247,242,0.45)'};`}>
        {t.nav.thisWeek}
      </a>
      <a href={aboutHref}
        style={`font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; font-weight: 600; color: ${isAbout ? '#C45C26' : 'rgba(250,247,242,0.45)'};`}>
        {t.nav.about}
      </a>
    </nav>
  </header>

  <main style="max-width: 42rem; margin: 0 auto; padding: 0 1.25rem 4rem;">
    <slot />
  </main>

  <footer class="border-t border-border-warm mt-16">
    <div class="max-w-2xl mx-auto px-5 py-8">

      <div class="grid grid-cols-2 gap-8 mb-8 text-sm md:grid-cols-3">

        <div>
          <p class="font-semibold text-ink dark:text-white mb-3 text-xs uppercase tracking-wider">
            {lang === 'es' ? 'Lugares de trabajo' : 'Work Spots'}
          </p>
          <div class="space-y-2">
            <a href={workHref} class="block text-muted hover:text-terracotta no-underline text-xs">
              {lang === 'es' ? 'Todos los lugares verificados' : 'All verified spots'}
            </a>
            <a href={fastestWifiHref} class="block text-muted hover:text-terracotta no-underline text-xs">
              {lang === 'es' ? 'WiFi más rápido' : 'Fastest WiFi ranked'}
            </a>
            <a href={wifiSpeedsHref} class="block text-muted hover:text-terracotta no-underline text-xs">
              {lang === 'es' ? 'Comparación WiFi' : 'WiFi speed comparison'}
            </a>
          </div>
        </div>

        <div>
          <p class="font-semibold text-ink dark:text-white mb-3 text-xs uppercase tracking-wider">
            {lang === 'es' ? 'Eventos' : 'Events'}
          </p>
          <div class="space-y-2">
            <a href={eventsHref} class="block text-muted hover:text-terracotta no-underline text-xs">
              {lang === 'es' ? 'Esta semana' : 'This week'}
            </a>
            <a href={archiveHref} class="block text-muted hover:text-terracotta no-underline text-xs">
              {lang === 'es' ? 'Eventos pasados' : 'Past events'}
            </a>
            <a href={sourcesHref} class="block text-muted hover:text-terracotta no-underline text-xs">
              {lang === 'es' ? 'Fuentes de eventos' : 'How we source events'}
            </a>
          </div>
        </div>

        <div>
          <p class="font-semibold text-ink dark:text-white mb-3 text-xs uppercase tracking-wider">
            Cartagena Up
          </p>
          <div class="space-y-2">
            <a href={aboutHref} class="block text-muted hover:text-terracotta no-underline text-xs">
              {lang === 'es' ? 'Acerca de' : 'About'}
            </a>
            <a href={venuesHref} class="block text-muted hover:text-terracotta no-underline text-xs">
              {lang === 'es' ? 'Espacios culturales' : 'Cultural venues'}
            </a>
            <a href="https://wa.me/573163946401?text=Hi! I found Cartagena Up." target="_blank" rel="noopener" class="block text-muted hover:text-terracotta no-underline text-xs">
              {lang === 'es' ? 'Contactar por WhatsApp' : 'Contact on WhatsApp'}
            </a>
          </div>
        </div>

      </div>

      <div class="border-t border-border-warm pt-6 flex flex-wrap items-center justify-between gap-4">
        <p class="text-xs text-muted">
          Cartagena Up · {lang === 'es' ? 'Por Yatan y Adri, residentes locales' : 'By Yatan and Adri, local residents'} · {t.footer.lastUpdated}{' '}
          {new Date().toLocaleDateString(lang === 'es' ? 'es-CO' : 'en-GB', { month: 'long', year: 'numeric' })}
        </p>
        <div class="flex gap-4">
          <a href={altPath} class="text-xs text-muted hover:text-terracotta no-underline">
            {lang === 'es' ? 'English' : 'Español'}
          </a>
          <a href="/rss.xml" class="text-xs text-muted hover:text-terracotta no-underline">
            RSS
          </a>
        </div>
      </div>

    </div>
  </footer>

  <script is:inline>
    document.addEventListener('astro:page-load', function() {
      var icon = document.getElementById('theme-icon');
      var btn  = document.getElementById('theme-toggle');
      var isDark = document.documentElement.classList.contains('dark');
      icon.textContent = isDark ? '☀' : '☾';
      btn.addEventListener('click', function() {
        isDark = document.documentElement.classList.toggle('dark');
        icon.textContent = isDark ? '☀' : '☾';
        localStorage.setItem('cu-theme', isDark ? 'dark' : 'light');
      });
    });
  </script>

</body>
</html>
