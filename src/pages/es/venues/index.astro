---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const lang = 'es';
const TYPE_LABELS = {
  'cultural-center': 'Centro cultural',
  'theatre': 'Teatro',
};

const venues = (await getCollection('venues', ({ data }) => data.active !== false))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Base
  title="Espacios Culturales en Cartagena"
  description="Centros culturales, teatros y espacios de eventos en Cartagena, Colombia."
  lang="es"
  canonicalUrl="https://cartagenaup.com/es/venues/">

  <div style="padding-top: 2rem;">
    <h1 style="font-family: Georgia, serif; font-size: 1.875rem; font-weight: 400; margin: 0 0 0.5rem; color: var(--fg);">
      Espacios Culturales en Cartagena
    </h1>
    <p style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 2rem; padding-bottom: 1.75rem; border-bottom: 1px solid var(--border);">
      Espacios de eventos, centros culturales e instituciones que vale la pena conocer.
    </p>

    <div style="display: grid; gap: 1.25rem;">
      {venues.map(venue => (
        <div style="border: 0.5px solid var(--card-border); border-radius: 12px; padding: 1.25rem; background: var(--card-bg);">
          <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 0.5rem;">
            <div>
              <a href={`/es/venues/${venue.data.slug}/`}
                style="font-family: Georgia, serif; font-size: 1.125rem; color: var(--fg); text-decoration: none;">
                {venue.data.name}
              </a>
              <p style="font-size: 0.75rem; color: var(--text-muted); margin: 0.15rem 0 0;">
                {venue.data.neighborhood}
                {venue.data.type && ` · ${TYPE_LABELS[venue.data.type] || venue.data.type}`}
              </p>
            </div>
            {venue.data.also_workplace && (
              <span style="font-size: 0.65rem; font-weight: 700; background: rgba(196,92,38,0.1); color: #C45C26; padding: 0.25rem 0.6rem; border-radius: 9999px; white-space: nowrap; flex-shrink: 0;">
                También un lugar de trabajo
              </span>
            )}
          </div>
          <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; margin: 0 0 0.75rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
            {venue.data.description_es}
          </p>
          {venue.data.instagram && (
            <a href={`https://instagram.com/${venue.data.instagram.replace('@', '')}`}
              target="_blank" rel="noopener"
              style="font-size: 0.75rem; color: var(--text-muted); text-decoration: none; display: block; margin-bottom: 0.5rem;">
              {venue.data.instagram}
            </a>
          )}
          <a href={`/es/venues/${venue.data.slug}/`}
            style="font-size: 0.75rem; color: #C45C26; text-decoration: none; font-weight: 600;">
            Ver espacio →
          </a>
        </div>
      ))}
    </div>
  </div>

</Base>
