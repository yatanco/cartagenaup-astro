---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';

const places = await getCollection('workPlaces',
  ({ data }) => data.active === true && data.status !== 'closed'
);
const sorted = places.sort((a, b) => b.data.wifi_down_mbps - a.data.wifi_down_mbps);

const avg = Math.round(
  sorted.reduce((sum, p) => sum + p.data.wifi_down_mbps, 0) / sorted.length
);

const canonicalUrl = 'https://cartagenaup.com/es/work/wifi-speeds-cartagena/';
---

<Base
  title="Velocidades WiFi en Cafés de Cartagena — Medido en julio 2026"
  description={`Resultados reales de pruebas de velocidad WiFi en ${sorted.length} cafés y espacios de coworking en Cartagena, Colombia. Medido con Speedtest.net a servidores locales. Actualizado en julio 2026.`}
  lang="es"
  canonicalUrl={canonicalUrl}>

  <div style="padding-top: 2rem;">
    <h1 style="font-family: Georgia, serif; font-size: 1.875rem; font-weight: 400; margin: 0 0 1rem; color: var(--fg);">
      Velocidades WiFi en Cafés de Cartagena
    </h1>

    <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 0.5rem;">
      Cada velocidad fue medida en persona usando Speedtest.net a un servidor local en Cartagena. Última verificación: julio 2026 por Yatan y Adri, residentes de Cartagena.
    </p>

    <p style="font-size: 0.875rem; color: var(--fg); margin: 0 0 1.5rem; padding-bottom: 1.25rem; border-bottom: 1px solid var(--border);">
      <strong>Más rápido:</strong> 531 Mbps en Mientras (Getsemaní) · <strong>Promedio:</strong> {avg} Mbps · <strong>Más lento:</strong> 3 Mbps en Café San Alberto (trae un hotspot)
    </p>

    <div style="overflow-x: auto;">
      <table style="width: 100%; font-size: 0.8125rem; border-collapse: collapse;">
        <thead>
          <tr style="border-bottom: 1px solid var(--border); text-align: left; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted);">
            <th style="padding: 0.5rem 0.75rem 0.5rem 0; font-weight: 600;">Café</th>
            <th style="padding: 0.5rem 0.75rem 0.5rem 0; font-weight: 600;">Zona</th>
            <th style="padding: 0.5rem 0.75rem 0.5rem 0; font-weight: 600;">↓ Mbps</th>
            <th style="padding: 0.5rem 0.75rem 0.5rem 0; font-weight: 600;">↑ Mbps</th>
            <th style="padding: 0.5rem 0.75rem 0.5rem 0; font-weight: 600;">Ping</th>
            <th style="padding: 0.5rem 0.75rem 0.5rem 0; font-weight: 600;">A/C</th>
            <th style="padding: 0.5rem 0 0.5rem 0; font-weight: 600;">Verificado</th>
          </tr>
        </thead>
        <tbody>
          {sorted.map(p => (
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 0.75rem 0.75rem 0.75rem 0;">
                <a href={`/es/work/${p.data.slug}/`} style="color: #C45C26; text-decoration: none; font-weight: 500;">
                  {p.data.name}
                </a>
              </td>
              <td style="padding: 0.75rem 0.75rem 0.75rem 0; color: var(--text-muted);">
                {p.data.neighborhood}
              </td>
              <td style="padding: 0.75rem 0.75rem 0.75rem 0; font-weight: 600; color: var(--fg);">
                {p.data.wifi_down_mbps}
              </td>
              <td style="padding: 0.75rem 0.75rem 0.75rem 0; font-weight: 600; color: var(--fg);">
                {p.data.wifi_up_mbps}
              </td>
              <td style="padding: 0.75rem 0.75rem 0.75rem 0; color: var(--text-muted);">
                {p.data.wifi_latency_ms ? `${p.data.wifi_latency_ms}ms` : '—'}
              </td>
              <td style="padding: 0.75rem 0.75rem 0.75rem 0;">
                {p.data.ac ? '✓' : '—'}
              </td>
              <td style="padding: 0.75rem 0 0.75rem 0; color: var(--text-muted); font-size: 0.75rem;">
                {p.data.last_tested}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 1.5rem;">
      Las velocidades varían según la hora del día y el número de usuarios. Todas las mediciones se hicieron a un servidor local de Fibrazo o Movistar en Cartagena. Lugares cerrados excluidos.
      <a href="/es/work/" style="color: #C45C26; text-decoration: none; margin-left: 0.25rem;">Ver todos los lugares verificados →</a>
    </p>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": "Velocidades WiFi en Cafés de Cartagena",
    "description": `Mediciones reales de velocidad WiFi en ${sorted.length} cafés y espacios de coworking en Cartagena, Colombia. Medido con Speedtest.net a servidores locales.`,
    "dateModified": new Date().toISOString().split('T')[0],
    "creator": [
      { "@type": "Person", "name": "Yatan", "description": "Residente de Cartagena desde 2021" },
      { "@type": "Person", "name": "Adri", "description": "Residente de Cartagena desde 2010" }
    ],
    "spatialCoverage": { "@type": "Place", "name": "Cartagena de Indias, Colombia" },
    "license": "https://creativecommons.org/licenses/by/4.0/"
  })} />

</Base>
