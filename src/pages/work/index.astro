---
import Base from '../../layouts/Base.astro';
import PlaceCard from '../../components/PlaceCard.astro';
import WhatsAppCTA from '../../components/WhatsAppCTA.astro';
import { getCollection } from 'astro:content';

const lang = 'en';
const places = (await getCollection('workPlaces', ({ data }) => data.active === true))
  .sort((a, b) => b.data.last_tested.localeCompare(a.data.last_tested));
---

<Base
  title="Work in Cartagena"
  description="WiFi-tested cafés and coworking spaces in Cartagena, Colombia — verified in person. Updated June 2026."
  lang="en"
  canonicalUrl="https://cartagenaup.com/work/">

  <div style="padding-top: 2rem;">
    <h1 style="font-family: Georgia, serif; font-size: 1.875rem; font-weight: 400; margin: 0 0 1.25rem; color: var(--fg);">
      Work in Cartagena
    </h1>

    <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 1rem;">
      {places.length} WiFi-tested work spots in Cartagena, Colombia — speeds measured in person using Speedtest.net, verified July 2026 by local residents.
    </p>

    <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 2rem; padding-bottom: 1.75rem; border-bottom: 1px solid var(--border);">
      I've been living in Cartagena since 2021 and work remotely from here. The question "where do I work today?" comes up constantly — and finding a good answer in this city is harder than it should be. WiFi quality varies wildly, AC is non-negotiable in the heat, and most guides are years out of date.
      <br /><br />
      I test every spot myself with a speed test and go back regularly. My priorities: fast and reliable internet, good coffee, and somewhere nearby to take a real break — a beach, a fort, a park. Cartagena has all of these if you know where to look.
      <br /><br />
      Whether you're looking for a coworking space with reliable upload speeds for video calls, or a quiet café to work from for a few hours, this is the only list in Cartagena with real speed test data and honest notes about what each place is actually like.
      <br /><br />
      Here's what I've found so far.
    </p>

    {places.map(place => (
      <PlaceCard place={place.data} lang={lang} />
    ))}

    <WhatsAppCTA lang="en" />

    <!-- FAQ -->
    <section style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border);">
      <h2 style="font-family: Georgia, serif; font-size: 1.5rem; font-weight: 400; margin: 0 0 1.5rem; color: var(--fg);">
        Frequently Asked Questions
      </h2>

      <div style="display: grid; gap: 1.5rem;">
        <div>
          <h3 style="font-family: Georgia, serif; font-size: 1.0625rem; font-weight: 400; margin: 0 0 0.375rem; color: var(--fg);">
            What café has the fastest WiFi in Cartagena?
          </h3>
          <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin: 0;">
            Mientras in Getsemaní — 531 Mbps down / 386 Mbps up, verified July 2026 using Speedtest.net to a local Cartagena server.
          </p>
        </div>

        <div>
          <h3 style="font-family: Georgia, serif; font-size: 1.0625rem; font-weight: 400; margin: 0 0 0.375rem; color: var(--fg);">
            Which cafés in Cartagena have AC and good WiFi?
          </h3>
          <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin: 0;">
            The best combination of fast WiFi and AC: Concreto Work and Coffee in Bocagrande (85/88 Mbps, 12ms ping), Época Café Bar in Centro Histórico (64/85 Mbps), and Libertario in Getsemaní (47/48 Mbps). All verified July 2026.
          </p>
        </div>

        <div>
          <h3 style="font-family: Georgia, serif; font-size: 1.0625rem; font-weight: 400; margin: 0 0 0.375rem; color: var(--fg);">
            Is there coworking in Cartagena?
          </h3>
          <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin: 0;">
            Yes. CoWork Cartagena operates from the Centro de Convenciones, 3rd floor, Getsemaní (Calle 24 #8a-344) — a dedicated coworking space with hourly, daily, and monthly plans. Café-based coworking is also viable at Concreto Work and Coffee and La Triada Punto y Sazón.
          </p>
        </div>

        <div>
          <h3 style="font-family: Georgia, serif; font-size: 1.0625rem; font-weight: 400; margin: 0 0 0.375rem; color: var(--fg);">
            Which Cartagena cafés are open early for remote work?
          </h3>
          <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin: 0;">
            La Triada Punto y Sazón in Manga opens at 7am — rare for Cartagena. Most other cafés open between 8am and 9am.
          </p>
        </div>

        <div>
          <h3 style="font-family: Georgia, serif; font-size: 1.0625rem; font-weight: 400; margin: 0 0 0.375rem; color: var(--fg);">
            Does Café San Alberto have good WiFi?
          </h3>
          <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin: 0;">
            No. Measured at 3 Mbps down / 1 Mbps up in July 2026 — bring a hotspot. The coffee and location on Plaza Santo Domingo are exceptional.
          </p>
        </div>
      </div>
    </section>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What café has the fastest WiFi in Cartagena?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Mientras in Getsemaní — 531 Mbps down / 386 Mbps up, verified July 2026 using Speedtest.net to a local Cartagena server."
        }
      },
      {
        "@type": "Question",
        "name": "Which cafés in Cartagena have AC and good WiFi?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The best combination of fast WiFi and AC: Concreto Work and Coffee in Bocagrande (85/88 Mbps), Época Café Bar in Centro Histórico (64/85 Mbps), and Libertario in Getsemaní (47/48 Mbps). All verified July 2026."
        }
      },
      {
        "@type": "Question",
        "name": "Is there coworking in Cartagena?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. CoWork Cartagena operates from the Centro de Convenciones, 3rd floor, Getsemaní (Calle 24 #8a-344) with hourly, daily, and monthly plans. Café-based coworking is also viable at Concreto Work and Coffee and La Triada Punto y Sazón."
        }
      },
      {
        "@type": "Question",
        "name": "Which Cartagena cafés are open early for remote work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La Triada Punto y Sazón in Manga opens at 7am — rare for Cartagena. Most other cafés open between 8am and 9am."
        }
      },
      {
        "@type": "Question",
        "name": "Does Café San Alberto have good WiFi?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Measured at 3 Mbps down / 1 Mbps up in July 2026 — bring a hotspot. The coffee and Plaza Santo Domingo location are exceptional."
        }
      }
    ]
  })} />

</Base>
