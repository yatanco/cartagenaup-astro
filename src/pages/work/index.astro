---
import Base from '../../layouts/Base.astro';
import PlaceCard from '../../components/PlaceCard.astro';
import WhatsAppCTA from '../../components/WhatsAppCTA.astro';
import { getCollection } from 'astro:content';

const lang = 'en';
const places = (await getCollection('workPlaces', ({ data }) => data.active === true))
  .sort((a, b) => b.data.last_tested.localeCompare(a.data.last_tested));
const rankable = places.filter(p => p.data.status !== 'closed');
const rankedCount = rankable.length;

const sorted = [...rankable].sort((a, b) =>
  (b.data.wifi_down_mbps ?? 0) - (a.data.wifi_down_mbps ?? 0)
);
const fastest = sorted[0]?.data;
const slowest = sorted[sorted.length - 1]?.data;
const sanAlberto = rankable.find(p => p.data.slug === 'cafe-san-alberto')?.data;
const goodForCalls = rankable
  .filter(p => p.data.video_calls === 'good')
  .sort((a, b) => (b.data.wifi_down_mbps ?? 0) - (a.data.wifi_down_mbps ?? 0))
  .slice(0, 3);

const mostRecent = [...rankable].sort((a, b) => b.data.last_tested.localeCompare(a.data.last_tested))[0]?.data.last_tested;
const verifiedMonth = mostRecent
  ? new Date(mostRecent + 'T12:00:00').toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })
  : 'July 2026';
---

<Base
  title="WiFi-Tested Cafés & Coworking in Cartagena"
  description={`The only guide to cafés and coworking in Cartagena with real WiFi speed tests — download, upload, and ping measured in person. Verified ${verifiedMonth} by local residents Yatan and Adri.`}
  lang="en"
  canonicalUrl="https://cartagenaup.com/work/">

  <div style="padding-top: 2rem;">
    <h1 style="font-family: Georgia, serif; font-size: 1.875rem; font-weight: 400; margin: 0 0 1.25rem; color: var(--fg);">
      WiFi-Tested Cafés & Coworking in Cartagena
    </h1>

    <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 1rem;">
      {places.length} WiFi-tested work spots in Cartagena, Colombia — speeds measured in person using Speedtest.net, verified {verifiedMonth} by Yatan and Adri.
    </p>

    <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.5rem;">
      Sorted by most recently verified first.
    </p>

    <p style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 1.5rem;">
      <a href="/work/fastest-wifi-cartagena/" style="color: #C45C26; text-decoration: none;">
        See all {rankedCount} spots ranked by WiFi speed →
      </a>
    </p>

    <div style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.7; display: grid; gap: 1rem; margin-bottom: 2rem; padding-bottom: 1.75rem; border-bottom: 1px solid var(--border);">
      <p style="margin: 0;">
        We've been living in Cartagena — Yatan since 2021, Adri since 2010 — between us we have over 20 years of daily life in this city. The question "where do I work today?" comes up constantly, and finding a good answer is harder than it should be. WiFi quality varies wildly, AC is non-negotiable in the heat, and most guides are years out of date.
      </p>
      <p style="margin: 0;">
        We test every spot in person with a speed test and go back regularly. Our priorities: fast and reliable internet, good coffee, and somewhere nearby to take a real break — a beach, a fort, a park. Cartagena has all of these if you know where to look. Whether you need a coworking space with solid upload speeds for video calls, or a quiet café for a few focused hours, this is the only list in Cartagena with real speed test data and honest notes about what each place is actually like.
      </p>
      <p style="margin: 0;">Here's what we've found so far.</p>
    </div>

    {places.map(place => (
      <PlaceCard place={place.data} lang={lang} />
    ))}

    <WhatsAppCTA lang="en" />

    <a href="#top" style="font-size: 0.75rem; color: var(--text-muted); text-decoration: none; display: block; text-align: center; margin: 1rem 0 2rem;">
      ↑ Back to top
    </a>

    <!-- FAQ -->
    <section style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border);">
      <h2 style="font-family: Georgia, serif; font-size: 1.5rem; font-weight: 400; margin: 0 0 1.5rem; color: var(--fg);">
        Frequently Asked Questions
      </h2>

      <div style="display: grid; gap: 1.5rem;">
        <div>
          <h3 style="font-family: Georgia, serif; font-size: 1.0625rem; font-weight: 400; margin: 0 0 0.375rem; color: var(--fg);">
            What café has the fastest WiFi in Cartagena?
          </h3>
          <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin: 0;">
            {fastest?.name} in {fastest?.neighborhood} — {fastest?.wifi_down_mbps} Mbps down / {fastest?.wifi_up_mbps} Mbps up, verified {fastest?.last_tested} using Speedtest.net to a local Cartagena server.
          </p>
        </div>

        <div>
          <h3 style="font-family: Georgia, serif; font-size: 1.0625rem; font-weight: 400; margin: 0 0 0.375rem; color: var(--fg);">
            Which cafés in Cartagena have good WiFi for video calls?
          </h3>
          <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin: 0;">
            The best current options marked good for video calls are {goodForCalls.map(p => `${p.data.name} in ${p.data.neighborhood} (${p.data.wifi_down_mbps}/${p.data.wifi_up_mbps} Mbps${p.data.wifi_latency_ms ? `, ${p.data.wifi_latency_ms}ms ping` : ''})`).join(', ')}. The slowest active listing is {slowest?.name} at {slowest?.wifi_down_mbps} Mbps down.
          </p>
        </div>

        <div>
          <h3 style="font-family: Georgia, serif; font-size: 1.0625rem; font-weight: 400; margin: 0 0 0.375rem; color: var(--fg);">
            Is there coworking in Cartagena?
          </h3>
          <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin: 0;">
            Yes. CoWork Cartagena operates from the Centro de Convenciones, 3rd floor, Getsemaní (Calle 24 #8a-344) — a dedicated coworking space with hourly, daily, and monthly plans. Café-based coworking is also viable at Concreto Work and Coffee and La Triada Punto y Sazón.
          </p>
        </div>

        <div>
          <h3 style="font-family: Georgia, serif; font-size: 1.0625rem; font-weight: 400; margin: 0 0 0.375rem; color: var(--fg);">
            Which Cartagena cafés are open early for remote work?
          </h3>
          <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin: 0;">
            La Triada Punto y Sazón in Manga opens at 7am — rare for Cartagena. Most other cafés open between 8am and 9am.
          </p>
        </div>

        <div>
          <h3 style="font-family: Georgia, serif; font-size: 1.0625rem; font-weight: 400; margin: 0 0 0.375rem; color: var(--fg);">
            Does Café San Alberto have good WiFi?
          </h3>
          <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin: 0;">
            No. Measured at {sanAlberto?.wifi_down_mbps} Mbps down / {sanAlberto?.wifi_up_mbps} Mbps up, verified {sanAlberto?.last_tested} — bring a hotspot. The coffee and location on Plaza Santo Domingo are exceptional.
          </p>
        </div>
      </div>
    </section>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What café has the fastest WiFi in Cartagena?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `${fastest?.name} in ${fastest?.neighborhood} — ${fastest?.wifi_down_mbps} Mbps down / ${fastest?.wifi_up_mbps} Mbps up, verified ${fastest?.last_tested} using Speedtest.net to a local Cartagena server.`
        }
      },
      {
        "@type": "Question",
        "name": "Which cafés in Cartagena have good WiFi for video calls?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `The best current options marked good for video calls are ${goodForCalls.map(p => `${p.data.name} in ${p.data.neighborhood} (${p.data.wifi_down_mbps}/${p.data.wifi_up_mbps} Mbps)`).join(', ')}. The slowest active listing is ${slowest?.name} at ${slowest?.wifi_down_mbps} Mbps down.`
        }
      },
      {
        "@type": "Question",
        "name": "Is there coworking in Cartagena?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. CoWork Cartagena operates from the Centro de Convenciones, 3rd floor, Getsemaní (Calle 24 #8a-344) with hourly, daily, and monthly plans. Café-based coworking is also viable at Concreto Work and Coffee and La Triada Punto y Sazón."
        }
      },
      {
        "@type": "Question",
        "name": "Which Cartagena cafés are open early for remote work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "La Triada Punto y Sazón in Manga opens at 7am — rare for Cartagena. Most other cafés open between 8am and 9am."
        }
      },
      {
        "@type": "Question",
        "name": "Does Café San Alberto have good WiFi?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `No. Measured at ${sanAlberto?.wifi_down_mbps} Mbps down / ${sanAlberto?.wifi_up_mbps} Mbps up, verified ${sanAlberto?.last_tested} — bring a hotspot. The coffee and Plaza Santo Domingo location are exceptional.`
        }
      }
    ]
  })} />

</Base>
